\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{aliascnt}[2026/04/04 Local fallback for LNCS builds]

% Minimal fallback for classes that only need \newaliascnt to share a counter.
\newcommand{\newaliascnt}[2]{%
  \expandafter\let\csname c@#1\endcsname\csname c@#2\endcsname
  \expandafter\let\csname the#1\endcsname\csname the#2\endcsname
  \expandafter\@ifundefined{theH#2}{}{%
    \expandafter\let\csname theH#1\endcsname\csname theH#2\endcsname
  }%
}

\newcommand{\aliascntresetthe}[1]{}

\endinput
